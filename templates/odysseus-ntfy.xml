<Container version="2">
  <Name>Odysseus-ntfy</Name>
  <Repository>docker.io/binwiederhier/ntfy:latest</Repository>
  <Registry>https://registry.hub.docker.com</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/binwiederhier/ntfy/issues</Support>
  <Project>https://ntfy.sh</Project>
  <Overview>Notification service for Odysseus reminders and alerts (optional companion).</Overview>
  <Description>ntfy is a simple HTTP-based pub-sub notification service used by Odysseus for sending push notifications, reminders, and scheduled task alerts. This is an <b>optional companion</b> — Odysseus will work without it, but scheduled task notifications will not be delivered.</Description>
  <Category>Tools:Utilities</Category>
  <TemplateURL>https://raw.githubusercontent.com/realitymolder/Odysseus-Unraid/main/templates/odysseus-ntfy.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/pewdiepie-archdaemon/odysseus/dev/docs/odysseus.jpg</Icon>
  <Requires/>
  <Config Name="ntfy Port" Target="80" Default="8091" Mode="tcp" Description="ntfy HTTP port" Type="Port" Display="always" Required="true" Mask="false">8091</Config>
  <Config Name="ntfy Cache" Target="/var/cache/ntfy" Default="/mnt/user/appdata/odysseus/ntfy" Mode="rw" Description="ntfy cache directory" Type="Path" Display="always" Required="false" Mask="false">/mnt/user/appdata/odysseus/ntfy</Config>
  <Config Name="Base URL" Target="NTFY_BASE_URL" Default="http://localhost:8091" Description="ntfy base URL for notification links" Type="Variable" Display="always" Required="false" Mask="false">http://localhost:8091</Config>
</Container>
